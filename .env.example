# ══════════════════════════════════════════════════════════════
# Sacred Heart SMS — Environment Variables
# Copy this to .env and fill in real values
# NEVER commit .env to version control
# ══════════════════════════════════════════════════════════════

# ── Django Backend ──────────────────────────────────────────────
DJANGO_SECRET_KEY=change-this-to-a-50-char-random-secret-key-in-production
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com

# ── PostgreSQL ──────────────────────────────────────────────────
# Production (Neon): set DATABASE_URL to your Neon pooled connection string
# (Project → Connection Details → "Pooled connection", includes -pooler in
# the hostname and ?sslmode=require). When DATABASE_URL is set it takes
# priority over the DB_* vars below.
# DATABASE_URL=postgresql://user:password@ep-xxxx-pooler.region.aws.neon.tech/dbname?sslmode=require&channel_binding=require
# DATABASE_URL_UNPOOLED=postgresql://user:password@ep-xxxx.region.aws.neon.tech/dbname?sslmode=require&channel_binding=require

# Local dev (docker-compose Postgres) — used only if DATABASE_URL is unset.
DB_NAME=sacred_heart_sms
DB_USER=sms_user
DB_PASSWORD=choose-a-strong-password-here
DB_HOST=db
DB_PORT=5432

# ── Redis ───────────────────────────────────────────────────────
# Local dev (docker-compose): redis://redis:6379/0
# Production (Render): use an Upstash free Redis database — copy its
# "rediss://" (TLS) connection string here.
REDIS_URL=redis://redis:6379/0

# ── CORS / CSRF ─────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com
# Comma-separated regexes for additional allowed origins, e.g. Vercel
# preview deployments:
# CORS_ALLOWED_ORIGIN_REGEXES=^https://sacred-heart-sms-.*\.vercel\.app$

# Required in production for Django admin login to work behind Render's
# proxy — set to your backend's public URL(s), e.g.
# CSRF_TRUSTED_ORIGINS=https://sacred-heart-backend.onrender.com
CSRF_TRUSTED_ORIGINS=

# ── Email (Gmail SMTP example) ──────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=sacredheartsms@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password-here

# ── Media storage (Cloudflare R2) ────────────────────────────────
# Optional. If AWS_STORAGE_BUCKET_NAME is unset, uploaded files
# (student/teacher photos, receipts) are stored on local disk — fine
# for local dev, but ephemeral on Render. Set these for production.
# AWS_STORAGE_BUCKET_NAME=sacred-heart-sms-media
# AWS_ACCESS_KEY_ID=your-r2-access-key-id
# AWS_SECRET_ACCESS_KEY=your-r2-secret-access-key
# AWS_S3_ENDPOINT_URL=https://<account_id>.r2.cloudflarestorage.com
# AWS_S3_REGION_NAME=auto
# AWS_S3_CUSTOM_DOMAIN=pub-xxxxxxxx.r2.dev

# ── Next.js Frontend ────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Future: WhatsApp Business API ───────────────────────────────
# WHATSAPP_API_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=
